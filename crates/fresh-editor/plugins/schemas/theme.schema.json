    "ColorDef": {
      "description": "Serializable color representation",
      "anyOf": [
        {
          "description": "RGB color as [r, g, b]",
          "type": "array",
          "prefixItems": [
            {
              "type": "integer",
              "format": "uint8",
              "minimum": 0,
              "maximum": 255
            },
            {
