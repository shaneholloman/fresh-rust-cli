              "minimum": 0,
              "maximum": 255
            },
            {
              "type": "integer",
              "format": "uint8",
              "minimum": 0,
              "maximum": 255
            }
          ],
          "minItems": 3,
          "maxItems": 3
        },
        {
          "description": "Named color",
          "type": "string"
        }
      ]
    },
